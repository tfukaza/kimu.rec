---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories, getCategory } from "@/data/recommendations";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  return categories.map((category) => ({
    params: { category: category.slug },
  }));
}

const category = getCategory(Astro.params.category ?? "");
const items = (await getCollection("recommendations"))
  .filter((entry) => entry.data.category === category?.slug)
  .sort((a, b) => a.data.order - b.data.order || a.data.name.localeCompare(b.data.name));

if (!category) {
  return Astro.redirect("/");
}
---

<BaseLayout
  title={`${category.name} | Kimu.rec`}
  description={`Browse ${category.name.toLowerCase()} recommendations on Kimu.rec.`}
>
  <div class="page">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>{category.name}</span>
    </div>

    <section class="hero" aria-labelledby="category-title">
      <div>
        <p class="eyebrow">Category</p>
        <h1 id="category-title">{category.name}</h1>
        <span class="jp-subtitle">{category.jaName}</span>
        <p class="lede">{category.description}</p>
      </div>
      <div class="hero-drawing" aria-hidden="true">
        <span class="line-node"></span>
        <span class="material-symbols-outlined hero-icon">{category.icon}</span>
      </div>
    </section>

    <section class="section" aria-labelledby="items-title">
      <h2 id="items-title">Items</h2>
      <span class="jp-subtitle">アイテム</span>
      {
        items.length > 0 ? (
          <div class="grid item-grid">
            {items.map((item) => (
              <a class="card" href={`/category/${item.data.category}/${item.data.slug}`}>
                <div class="card-media" aria-hidden="true">
                  <span class="material-symbols-outlined">{item.data.icon}</span>
                </div>
                <div class="card-copy">
                  <h3>{item.data.name}</h3>
                  <span class="jp-subtitle">{item.data.jaName}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <p class="empty-state">
            This category exists in the source page, but it does not have recommendation entries yet.
          </p>
        )
      }
    </section>
  </div>
</BaseLayout>
